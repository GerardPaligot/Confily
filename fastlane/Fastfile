default_platform(:android)

PROJECT_ROOT = File.expand_path("..", __dir__).freeze

def read_app_property(key)
  paths = [
    File.join(PROJECT_ROOT, "config/app.properties.prod"),
    File.join(PROJECT_ROOT, "config/app.properties")
  ]
  paths.each do |path|
    next unless File.exist?(path)
    File.foreach(path) do |line|
      stripped = line.strip
      next if stripped.empty? || stripped.start_with?("#") || !stripped.include?("=")
      k, v = stripped.split("=", 2)
      return v.strip if k.strip == key
    end
  end
  nil
end

platform :android do
  desc "Upload the prebuilt release AAB to the Play Store on the given track"
  lane :deploy do |options|
    package_name = options[:package_name] || read_app_property("APPLICATION_ID")
    UI.user_error!("APPLICATION_ID not found in #{PROJECT_ROOT}/config/app.properties[.prod]") unless package_name

    upload_to_play_store(
      package_name: package_name,
      track: options[:track] || "internal",
      release_status: options[:release_status] || "draft",
      aab: options[:aab] || File.join(PROJECT_ROOT, "androidApp/build/outputs/bundle/release/androidApp-release.aab"),
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

DIAGNOSTICS_DIR = "/tmp/cd-diagnostics".freeze

def run_xcodebuild_logged(args, log_basename)
  require "fileutils"
  FileUtils.mkdir_p(DIAGNOSTICS_DIR)
  log_path = File.join(DIAGNOSTICS_DIR, log_basename)
  cmd_str = (["xcodebuild"] + args).map { |a| a.to_s.shellescape }.join(" ")
  begin
    sh "set -o pipefail; #{cmd_str} 2>&1 | tee #{log_path.shellescape}"
  rescue => e
    UI.error("xcodebuild failed; full log saved to #{log_path}")
    raise e
  end
end

platform :ios do
  desc "Build the iOS app and upload it to App Store Connect (available immediately on TestFlight)"
  lane :deploy do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: File.join(PROJECT_ROOT, "config/app_store_connect_key.p8"),
      duration: 1200,
      in_house: false
    )

    project_path = File.join(PROJECT_ROOT, "iosApp/iosApp.xcodeproj")
    build_dir = File.join(PROJECT_ROOT, "iosApp/build")
    archive_path = File.join(build_dir, "iosApp.xcarchive")
    export_options_path = File.join(build_dir, "ExportOptions.plist")
    require "fileutils"
    FileUtils.mkdir_p(build_dir)

    xcargs = []
    xcargs << "MARKETING_VERSION=#{options[:version_name]}" if options[:version_name]
    xcargs << "CURRENT_PROJECT_VERSION=#{options[:version_code]}" if options[:version_code]
    if ENV["IOS_PROVISIONING_PROFILE_NAME"]
      # Signing identity and provisioning profile are routed to the iosApp
      # target via iosApp/Generated.xcconfig (IOS_CODE_SIGN_IDENTITY,
      # IOS_PROVISIONING_PROFILE_SPECIFIER). Passing them as global xcargs
      # leaks into SPM resource-bundle targets, which auto-sign for
      # development and reject any manually specified Distribution identity
      # or profile. DEVELOPMENT_TEAM is the only signing setting that must
      # stay global — the SPM bundles need it to ad-hoc sign and it is
      # compatible with both manual and automatic signing.
      team_id = read_app_property("IOS_TEAM_ID")
      UI.user_error!("IOS_TEAM_ID must be set in #{PROJECT_ROOT}/config/app.properties[.prod] for manual signing") unless team_id
      xcargs << "DEVELOPMENT_TEAM=#{team_id}"
    end

    run_xcodebuild_logged(
      [
        "-scheme", "iosApp",
        "-project", project_path,
        "-configuration", "Release",
        "-destination", "generic/platform=iOS",
        "-archivePath", archive_path,
        *xcargs,
        "archive"
      ],
      "xcodebuild-archive.log"
    )

    team_id = read_app_property("IOS_TEAM_ID")
    bundle_id = read_app_property("IOS_BUNDLE_ID")
    profile_name = ENV["IOS_PROVISIONING_PROFILE_NAME"]
    UI.user_error!("IOS_TEAM_ID, IOS_BUNDLE_ID, and IOS_PROVISIONING_PROFILE_NAME must all be set for manual signing export") unless team_id && bundle_id && profile_name

    File.write(export_options_path, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>teamID</key>
        <string>#{team_id}</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>#{bundle_id}</key>
          <string>#{profile_name}</string>
        </dict>
      </dict>
      </plist>
    PLIST

    run_xcodebuild_logged(
      [
        "-exportArchive",
        "-archivePath", archive_path,
        "-exportPath", build_dir,
        "-exportOptionsPlist", export_options_path
      ],
      "xcodebuild-export.log"
    )

    ipa_path = Dir.glob(File.join(build_dir, "*.ipa")).first
    UI.user_error!("No IPA produced in #{build_dir}") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
